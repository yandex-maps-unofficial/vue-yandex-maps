{
    "name": "vue-yandex-maps-monorepo",
    "private": true,
    "type": "module",
    "scripts": {
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "build": "yarn workspace vue-yandex-maps build",
        "run:vue": "yarn workspace vue-yandex-maps build:package-only && yarn workspace example-vue dev",
        "run:nuxt": "yarn workspace vue-yandex-maps build && yarn workspace example-nuxt dev",
        "run:astro": "yarn workspace vue-yandex-maps build && yarn workspace example-astro dev",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "yarn lint --fix",
        "check": "yarn lint && yarn build && yarn docs:build",
        "publish": "yarn lint && yarn build && yarn workspace vue-yandex-maps npm:publish"
    },
    "dependencies": {
        "examples": "workspace:^",
        "puppeteer": "25.3.0",
        "vue-yandex-maps": "workspace:^"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/node": "26.1.1",
        "@typescript-eslint/eslint-plugin": "8.65.0",
        "@typescript-eslint/parser": "8.65.0",
        "eslint": "10.7.0",
        "eslint-plugin-import-x": "4.17.1",
        "eslint-plugin-vue": "10.10.0",
        "typescript": "7.0.2",
        "vite": "8.1.5",
        "vitepress": "1.6.4",
        "vue-eslint-parser": "10.4.1"
    },
    "workspaces": [
        "packages/*",
        "packages/examples/*"
    ],
    "packageManager": "yarn@4.17.1"
}
